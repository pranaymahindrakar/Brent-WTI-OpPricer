# Copy this file to .env and fill in your keys. Never commit the real .env.

# Required for the LLM insight panel (free key from aistudio.google.com).
GEMINI_API_KEY=

# Required for history backfill from FRED (free key from fred.stlouisfed.org).
FRED_API_KEY=

# Optional, for EIA cross-checks.
EIA_API_KEY=

# For the News tab (free tier: 100 req/day at newsapi.org).
NEWSAPI_KEY=

# Marketaux financial news + per-entity sentiment (free tier: 100 req/day, 3 articles/req).
MARKETAUX_KEY=

# Optional. Massive.com REST API (paid/keyed), used as the primary source for
# the Options and Energy Trends tabs; every call has a yfinance fallback so
# the app runs fine without this key. Get it from your massive.com dashboard.
# Never commit the real value; rotate it if it is ever pasted anywhere insecure.
MASSIVE_API_KEY=

# Optional overrides (defaults shown).
# DATA_DIR=data
# ZSCORE_WINDOW=60
# NEW_EXTREME_WINDOW=20
# DEFAULT_FREQ=1min
# POLL_SECONDS=60
# BAR_INTERVAL=1m
# BAD_TICK_PCT=0.10
# Z_ALERT=2.0
# VOL_SPIKE_MULT=3.0
# RECONCILE_TOL=1.50
# GEMINI_MODEL=gemini-2.0-flash
