# Copy this file to .streamlit/secrets.toml for LOCAL runs, OR paste these
# key = "value" lines into the Streamlit Community Cloud "Secrets" panel for
# production. Streamlit loads every key here into os.environ, so config.py's
# os.getenv(...) calls pick them up with no code change.
#
# All keys are optional. The app runs without any of them (manual seed / no LLM),
# but each one unlocks a feature:

GEMINI_API_KEY    = ""     # grounded LLM insight notes and chatbot
FRED_API_KEY      = ""     # 5-year daily history backfill + reconciliation
EIA_API_KEY       = ""     # optional settlement validation
NEWSAPI_KEY       = ""     # NewsAPI headlines tab
MARKETAUX_KEY     = ""     # energy-headline entity sentiment
MASSIVE_API_KEY   = ""     # Options/Energy Trends/Market Lens primary source; yfinance fallback if unset
